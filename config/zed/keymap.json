// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
	{
		"context": "Editor",
		"bindings": {
			"alt-shift-f": "editor::Format",
		},
	},
	{
		"context": "(Editor && extension == md)",
		"bindings": {
			"alt-d": "markdown::OpenPreview",
		},
	},
	{
		"context": "Workspace",
		"bindings": {
			"ctrl-shift-s": "workspace::SaveAll",
		},
	},
	{
		"context": "Editor && !menu",
		"bindings": {
			"ctrl-f": "buffer_search::Deploy", // vim default: page down
			"ctrl-y": "editor::Undo", // vim default: line up
			"ctrl-t": "pane::ReopenClosedItem", // vim default: go to older tag
			"ctrl-s": "workspace::Save", // vim default: show signature
			"ctrl-b": "workspace::ToggleLeftDock", // vim default: down
			"ctrl-w": "pane::CloseActiveItem",
			"ctrl-shift-e": "editor::ExpandMacroRecursively",
		},
	},
	{
		"context": "Editor && vim_mode == normal",
		"bindings": {
			"\\ y": ["workspace::SendKeystrokes", "\" + y"],
			"\\ a": ["workspace::SendKeystrokes", "g g V G"],
			"\\ p": ["workspace::SendKeystrokes", "\" + p"],
			"\\ x": ["workspace::SendKeystrokes", "\" + x"],
		},
	},
	{
		"context": "Editor && vim_mode == visual",
		"bindings": {
			"\\ y": ["workspace::SendKeystrokes", "\" + y"],
			"\\ a": ["workspace::SendKeystrokes", "g g V G"],
			"\\ p": ["workspace::SendKeystrokes", "\" + p"],
			"\\ x": ["workspace::SendKeystrokes", "\" + x"],
		},
	},
]
