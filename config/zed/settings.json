{
	"agent": {
		"enabled": false,
		"button": false,
		"favorite_models": [],
		"model_parameters": []
	},
	"auto_update": false,
	"base_keymap": "VSCode",
	"buffer_font_family": "Hack Nerd Font Mono",
	"buffer_font_size": 12,
	"buffer_line_height": "standard",
	"collaboration_panel": {
		"button": false
	},
	"disable_ai": true,
	"file_types": {
		"mdx": ["*.mdx"],
		"ini": ["*.meta"]
	},
	"git": {
		"inline_blame": {
			"delay_ms": 1000
		}
	},
	"git_panel": { "dock": "left" },
	"hard_tabs": true,
	"icon_theme": "VSCode Icons for Zed (Dark)",
	"languages": {
		"Nix": {
			"language_servers": ["nil", "!nixd"],
			"formatter": "language_server",
			"format_on_save": "off",
			"preferred_line_length": 80,
			"hard_tabs": false,
			"tab_size": 2
		},
		"JSON": {
			"format_on_save": "off"
		}
	},
	"linked_edits": true,
	"lsp": {
		"nil": {
			"settings": {
				"nix": {
					"flake": {
						"autoArchive": true
					}
				}
			}
		}
	},
	"minimap": {
		"show": "auto"
	},
	"on_last_window_closed": "quit_app",
	"outline_panel": {
		"button": false
	},
	"preview_tabs": {
		"enabled": false
	},
	"project_panel": {
		"entry_spacing": "standard",
		"file_icons": true,
		"folder_icons": true,
		"dock": "left"
	},
	"relative_line_numbers": "disabled",
	"show_edit_predictions": true,
	"show_whitespaces": "all",
	"tabs": {
		"file_icons": true,
		"git_status": true
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"terminal": {
		"font_size": 10,
		"font_family": "Hack Nerd Font Mono",
		"max_scroll_history_lines": 10000
	},
	"theme": {
		"mode": "system",
		"light": "One Light",
		"dark": "VSCode Dark Modern"
	},
	"theme_overrides": {
		"VSCode Dark Modern": {
			"border.focused": "#087F23FF",
			"element.background": "#087F23FF",
			"status_bar.background": "#0B8025FF",
			"panel.focused_border": "#087F23FF",
			"pane.focused_border": "#087F23FF",
			"syntax": {
				"constant.comment.todo": {
					"color": "#000000",
					"background_color": "#FF8C00",
					"font_weight": 900,
					"font_style": "italic"
				},
				"constant.comment.todo.text": {
					"color": "#000000",
					"background_color": "#FF8C00"
				},
				"string.comment.info": {
					"color": "#000000",
					"background_color": "#2563EB",
					"font_weight": 900,
					"font_style": "italic"
				},
				"string.comment.info.text": {
					"color": "#000000",
					"background_color": "#2563EB"
				},
				"keyword.comment.warn": {
					"color": "#000000",
					"background_color": "#FBBF24",
					"font_weight": 900,
					"font_style": "italic"
				},
				"keyword.comment.warn.text": {
					"color": "#000000",
					"background_color": "#FBBF24"
				},
				"property.comment.error": {
					"color": "#000000",
					"background_color": "#DC2626",
					"font_weight": 900,
					"font_style": "italic"
				},
				"property.comment.error.text": {
					"color": "#000000",
					"background_color": "#DC2626"
				},
				"title": {
					"color": "#4D9CD6FF"
				},
				"primary": {
					"color": "#087F23FF"
				},
				"emphasis": {
					"color": "#C586C0FF",
					"font_style": "italic"
				},
				"link_text": {
					"color": "#ce9178FF"
				}
			}
		}
	},
	"toolbar": {
		"agent_review": false
	},
	"ui_font_family": ".ZedSans",
	"ui_font_size": 16,
	"vim": {
		"toggle_relative_line_numbers": true
	},
	"vim_mode": true,
	"when_closing_with_no_tabs": "keep_window_open",
	"which_key": {
		"enabled": true
	}
}
