{
	"agent": {
		"enabled": false,
		"button": false,
		"favorite_models": [],
		"model_parameters": [],
	},
	"auto_update": false,
	"base_keymap": "VSCode",
	"buffer_font_family": "Hack Nerd Font Mono",
	"buffer_font_size": 14,
	"buffer_line_height": "standard",
	"collaboration_panel": {
		"button": false,
	},
	"disable_ai": true,
	"file_types": {
		"mdx": ["*.mdx"],
		"ini": ["*.meta"],
	},
	"git": {
		"inline_blame": {
			"delay_ms": 1000,
		},
	},
	"hard_tabs": true,
	"icon_theme": "VSCode Icons for Zed (Dark)",
	"languages": {
		"Nix": {
			"language_servers": ["nil", "!nixd"],
			"formatter": "language_server",
			"format_on_save": "off",
			"preferred_line_length": 80,
			"hard_tabs": false,
			"tab_size": 2,
		},
	},
	"linked_edits": true,
	"minimap": {
		"show": "auto",
	},
	"on_last_window_closed": "quit_app",
	"outline_panel": {
		"button": false,
	},
	"preview_tabs": {
		"enabled": false,
	},
	"project_panel": {
		"entry_spacing": "standard",
	},
	"relative_line_numbers": "disabled",
	"show_edit_predictions": true,
	"show_whitespaces": "all",
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
	"terminal": {
		"font_size": 10,
		"font_family": "Hack Nerd Font Mono",
		"max_scroll_history_lines": 10000,
	},
	"theme": {
		"mode": "system",
		"light": "One Light",
		"dark": "VSCode Dark Modern",
	},
	"theme_overrides": {
		"VSCode Dark Modern": {
			"syntax": {
				"constant.comment.todo": {
					"color": "#000000",
					"background_color": "#FF8C00",
					"font_weight": 900,
					"font_style": "italic",
				},
				"constant.comment.todo.text": {
					"color": "#000000",
					"background_color": "#FF8C00",
				},
				"string.comment.info": {
					"color": "#000000",
					"background_color": "#2563EB",
					"font_weight": 900,
					"font_style": "italic",
				},
				"string.comment.info.text": {
					"color": "#000000",
					"background_color": "#2563EB",
				},
				"keyword.comment.warn": {
					"color": "#000000",
					"background_color": "#FBBF24",
					"font_weight": 900,
					"font_style": "italic",
				},
				"keyword.comment.warn.text": {
					"color": "#000000",
					"background_color": "#FBBF24",
				},
				"property.comment.error": {
					"color": "#000000",
					"background_color": "#DC2626",
					"font_weight": 900,
					"font_style": "italic",
				},
				"property.comment.error.text": {
					"color": "#000000",
					"background_color": "#DC2626",
				},
			},
		},
	},
	"toolbar": {
		"agent_review": false,
	},
	"ui_font_family": ".ZedSans",
	"ui_font_size": 18,
	"vim": {
		"toggle_relative_line_numbers": true,
	},
	"vim_mode": true,
	"when_closing_with_no_tabs": "keep_window_open",
	"which_key": {
		"enabled": true,
	},
}
