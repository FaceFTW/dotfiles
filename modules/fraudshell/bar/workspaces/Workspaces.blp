using Gtk 4.0;

template $WorkspacesWidget: Gtk.Box {
	orientation: horizontal;
	spacing: 0;

	css-classes: [
		"bar-item", "workspaces", "compact"
	];

	Gtk.FlowBox content_box {
		orientation: horizontal;
		column-spacing: 0;
		row-spacing: 0;
		hexpand: false;
		vexpand: false;
		halign: start;

		css-classes: [
			"content",
		];

	}

}
