using Gtk 4.0;

template $WorkspaceButton: Gtk.Button {
	halign: center;
	valign: center;

	css-classes: [
		"workspace",
	];

	Box {
		css-classes: [
			"workspace",
		];
		orientation: horizontal;
		spacing: 1;

		Label workspace_id {
			xalign: 0.5;
		}

		Gtk.FlowBox windows_box {
			orientation: horizontal;

			max-children-per-line: 99;
			column-spacing: 0;
			row-spacing: 0;
			visible: false;

			halign: start;

			css-classes: [
				"content",
			];

		}
	}
}
